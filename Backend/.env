# ==============================
# SERVER CONFIG
# ==============================
PORT=5000

# ==============================
# DATABASE (MongoDB)
# ==============================
MONGO_URI=mongodb://127.0.0.1:27017/jobmanager

# If using MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/jobmanager

# ==============================
# JWT (AUTHENTICATION)
# ==============================
ACCESS_TOKEN_SECRET=mysecret123
REFRESH_TOKEN_SECRET=myrefreshsecret123

# Token expiry (optional but useful)
ACCESS_TOKEN_EXPIRE=1d
REFRESH_TOKEN_EXPIRE=7d

# ==============================
# BCRYPT (optional config)
# ==============================
SALT_ROUNDS=10

# ==============================
# FRONTEND URL (for CORS)
# ==============================
CLIENT_URL=http://localhost:3000